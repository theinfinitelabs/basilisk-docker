# Python path for Basilisk modules
PYTHONPATH=/app/basilisk/dist3

# Suppress bytecode generation
PYTHONDONTWRITEBYTECODE=1

# Suppress Python buffering for cleaner container logs
PYTHONUNBUFFERED=1